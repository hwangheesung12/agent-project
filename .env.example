# NCBI 계정에서 발급받은 API Key를 입력하세요.
NCBI_API_KEY=your_ncbi_api_key_here

# NCBI 요청 식별용 이메일을 입력하세요.
NCBI_EMAIL=your_email@example.com

# LangChain 챗봇 가드레일에서 사용할 OpenAI API Key를 입력하세요.
OPENAI_API_KEY=your_openai_api_key_here

# 선택 사항: 의료 안전 가드레일 분류에 사용할 채팅 모델명을 지정하세요.
OPENAI_CHAT_MODEL=gpt-4o-mini

# 비워 두지 말고 SQLite DB 파일 경로를 지정하세요.
PUBMED_DB_PATH=pubmed.db
